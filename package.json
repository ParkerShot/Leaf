{
  "name": "leaf",
  "version": "1.5.1",
  "description": "Leaf — минималистичные заметки",
  "main": "main.js",
  "author": {
    "name": "ParkerShot",
    "url": "https://github.com/ParkerShot"
  },
  "license": "MIT",
  "homepage": "https://github.com/ParkerShot/Leaf",
  "repository": {
    "type": "git",
    "url": "https://github.com/ParkerShot/Leaf.git"
  },
  "bugs": {
    "url": "https://github.com/ParkerShot/Leaf/issues"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "release": "electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.leaf.app",
    "productName": "Leaf",
    "copyright": "Copyright © 2026 ParkerShot",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "deleteAppDataOnUninstall": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ParkerShot",
        "repo": "Leaf",
        "releaseType": "release"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "app.js",
      "icon.ico",
      "fonts/**/*"
    ]
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
